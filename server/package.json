{
  "name": "BarakatHub-karbala-server",
  "version": "2.0.0",
  "description": "BarakatHub Karbala — Backend Server | پلتفرم رسانه‌ای اسلامی کربلا",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start":   "node index.js",
    "dev":     "node --watch index.js",
    "pm2":     "pm2 start index.js --name BarakatHub --watch",
    "logs":    "pm2 logs BarakatHub",
    "restart": "pm2 restart BarakatHub"
  },
  "dependencies": {
    "express":            "^4.19.2",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "multer":             "^1.4.5-lts.1",
    "axios":              "^1.7.2",
    "form-data":          "^4.0.0",
    "fluent-ffmpeg":      "^2.1.3",
    "@aws-sdk/client-s3": "^3.600.0",
    "helmet":             "^7.1.0",
    "express-rate-limit": "^7.3.1",
    "express-slow-down":  "^2.0.3",
    "jsonwebtoken":       "^9.0.2",
    "morgan":             "^1.10.0",
    "chalk":              "^5.3.0",
    "uuid":               "^10.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
