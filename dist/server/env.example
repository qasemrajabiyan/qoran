# ============================================================
# BarakatHub Karbala — Environment Variables
# این فایل را کپی کنید به .env و مقادیر را پر کنید
# ============================================================

# سرور
PORT=3001
NODE_ENV=production
BASE_URL=https://api.barakathub.com

# آدرس‌های مجاز (با کاما جدا کنید)
ALLOWED_ORIGINS=https://barakathub.com,https://www.barakathub.com

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# Admin API Key
ADMIN_API_KEY=your-admin-api-key-here

# ─────────────────────────────────────────────────────────────
# Cloudflare D1 — دیتابیس
# ─────────────────────────────────────────────────────────────
# Account ID را از: dash.cloudflare.com → راست پایین → Account ID
CF_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database ID را از: D1 → barakathub-db → Database ID
CF_D1_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# API Token را از: My Profile → API Tokens → Create Token
# مجوزهای لازم: D1:Edit
CF_D1_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Cloudflare R2 — ذخیره ویدیو و صوت
# ─────────────────────────────────────────────────────────────
CF_R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CF_R2_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CF_R2_BUCKET=barakathub-media
CF_R2_PUBLIC_URL=https://media.barakathub.com

# ─────────────────────────────────────────────────────────────
# ElevenLabs — دوبله صدا
# ─────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# OpenAI — استخراج متن از ویدیو
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Claude — ترجمه متن
# ─────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Resend — ایمیل
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Google OAuth
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=https://barakathub.com/auth/google/callback
