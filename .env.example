# ============================================================
# FILE: .env.example
# ROLE: متغیرهای محیطی — این فایل را کپی کنید به .env
# PROJECT: BarakatHub Karbala Backend
# ============================================================
# دستور: copy .env.example .env
# سپس مقادیر واقعی را در .env وارد کنید
# هرگز فایل .env را به GitHub push نکنید
# ============================================================

# ── سرور ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001

# ── CORS — آدرس‌های مجاز (با کاما جدا کنید) ──────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# ── امنیت JWT ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ── کلید API ادمین ────────────────────────────────────────
ADMIN_API_KEY=change-this-to-a-strong-random-api-key

# ── ElevenLabs — دوبله صدا ────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── OpenAI Whisper — تبدیل گفتار به متن ──────────────────
OPENAI_API_KEY=

# ── Claude API — ترجمه متن ────────────────────────────────
CLAUDE_API_KEY=

# ── Cloudflare R2 — ذخیره ویدیو و صوت ────────────────────
CF_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_KEY=
CF_R2_BUCKET=BarakatHub-media
CF_R2_PUBLIC_URL=
